# Supabase (Cloud mode)
NUXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NUXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# API Gateway (AWS Lambda) — Cloud mode
NUXT_PUBLIC_API_GATEWAY_URL=https://YOUR_API_ID.execute-api.ap-southeast-1.amazonaws.com/prod

# App URL
NUXT_PUBLIC_APP_URL=http://localhost:3000

# Backend mode: 'true' = POC mock (hardcoded creds, IndexedDB), 'false' = Cloud (Supabase + Lambda)
NUXT_PUBLIC_USE_MOCK_BACKEND=true

# Admin emails (comma-separated) — used for role detection in cloud mode
ADMIN_EMAILS=admin@example.com
