# ── Dependencies ───────────────────────────────
node_modules/

# ── Nuxt / build output ────────────────────────
.nuxt/
.output/
.data/
dist/
.nitro/
.cache/

# ── Secrets / environment ──────────────────────
# KHÔNG commit .env thật (chỉ giữ .env.example)
.env
.env.*
!.env.example

# ── Logs & OS junk ─────────────────────────────
*.log
npm-debug.log*
.DS_Store
Thumbs.db

# ── Editor / misc ──────────────────────────────
.vscode/
*.local

# ── Media / audio (host trên S3, KHÔNG commit vào git) ──
# File nhạc nền nặng → upload thẳng S3; giữ aws/s3/link.txt để tra nguồn.
*.mp3
*.wav
*.m4a
