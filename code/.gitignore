# ── Dependencies ───────────────────────────────
node_modules/

# ── Nuxt / build output ────────────────────────
.nuxt/
.output/
.data/
dist/
.nitro/
.cache/

# ── Secrets / environment ──────────────────────
# KHÔNG commit .env thật (chỉ giữ .env.example)
.env
.env.*
!.env.example

# ── Logs & OS junk ─────────────────────────────
*.log
npm-debug.log*
.DS_Store
Thumbs.db

# ── Editor / misc ──────────────────────────────
.vscode/
*.local

# ── Media / audio (host trên S3, KHÔNG commit vào git) ──
# File nhạc nền nặng → upload thẳng S3; giữ aws/s3/link.txt để tra nguồn.
*.mp3
*.wav
*.m4a

# ── AWS build artifacts / scratch (chứa secret trong log → KHÔNG commit) ──
aws/**/function.zip
aws/**/package/
aws/**/log.txt

# ── Python venv + model artifact cho lambda có bước "prepare model" local
# (vd emotion-detector: venv_prepare/venv_runtime nặng ~1-2GB; model/ chứa .onnx
# ~80-90MB tải/export từ HuggingFace — tự chạy prepare_model.py để tạo lại, KHÔNG commit) ──
aws/**/venv*/
aws/**/model/

# ── Python cache ───────────────────────────────
__pycache__/
*.pyc

# ── Per-user / scratch (không thuộc project) ───
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/cache
prompt để chạy lại.txt
